  },
  "bin": {
    "compile-epub": "dist/cli.js"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "katex": "^0.17.0",
    "marked": "^18.0.5",
    "marked-katex-extension": "^5.1.10"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^20.19.43",
    "fast-xml-parser": "^5.9.3",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
