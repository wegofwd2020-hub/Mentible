{
  "name": "@studybuddyq/compiler",
  "version": "0.1.0",
  "private": true,
  "description": "StudyBuddy Q artifact compiler — canonical book.json → EPUB3 (PDF/MOBI later). Server-side; not part of the Expo app bundle. See docs/COMPILE_PIPELINE_PLAN.md.",
  "license": "UNLICENSED",
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
