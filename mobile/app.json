{
  "expo": {
    "name": "Mentible",
    "slug": "studybuddy-q",
    "version": "0.2.3",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "web": {
      "name": "Mentible",
      "shortName": "Mentible",
      "favicon": "./assets/favicon.png"
    },
    "android": {
      "package": "com.wegofwd2020.studybuddyq",
      "versionCode": 15,
      "permissions": ["android.permission.INTERNET"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": false
        }
      ],
      "./plugins/withReleaseSigning.js"
    ],
    "scheme": "mentible",
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/demos/mentible"
    }
  }
}
