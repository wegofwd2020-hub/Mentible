# StudyBuddy Q — mobile environment
# Copy to .env.local and fill in the correct value for your setup.
# .env.local is gitignored and never committed.

# Backend URL the mobile app sends requests to.
#
# Android emulator on the same machine as the API:
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8001
#
# Physical Android device on the same LAN (replace with your machine's LAN IP):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:8001

# Supabase identity (ADR-014 D1, O1). Public client-side values from your Supabase
# project (Settings → API). Unset = identity disabled (anonymous demo); set both to
# enable login. The anon key is public by design (RLS/JWT protect data), but still
# keep it in .env.local, not committed.
# EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-key>
